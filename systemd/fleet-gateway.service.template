[Unit]
Description=Fleet Gateway
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
WorkingDirectory={{FLEET_DIR}}
EnvironmentFile=-{{FLEET_DIR}}/.env
Environment=PATH={{VENDOR_BIN_DIR}}:/usr/local/bin:/usr/bin:/bin
Environment=HOME={{HOME}}
Environment=NODE_OPTIONS=--max-old-space-size=4096
ExecStartPre=/bin/bash -c 'test ! -f {{FLEET_DIR}}/.fleet-paused || (echo "Fleet is PAUSED" && exit 1)'
ExecStartPre=/bin/bash -c 'curl -sf http://localhost:8000/healthz >/dev/null 2>&1 || (echo "MC is DOWN" && exit 1)'
# OCF_GATEWAY_PORT is for the OCF Python gateway (port 9400) — NOT for the vendor.
# The vendor gateway reads its port from ~/.openarms/openarms.json (gateway.port).
# Do NOT pass --port here; it would collide with the OCF gateway.
ExecStart=/bin/bash -c 'exec {{VENDOR_BIN}} gateway run'
# BUDGET PROTECTION — DO NOT CHANGE TO Restart=always
# Restart=always causes a restart storm when OCMC is down: ExecStartPre fails,
# systemd restarts, fails again, forever. Each cycle spawns processes.
# With on-failure: ExecStartPre failure = exit 1 = failure = restart after 30s.
# Gateway stays off until OCMC comes up. ZERO Claude calls when OCMC is down.
#
# SIGUSR1 handling: the gateway exits with code 0 on SIGUSR1 (config reload).
# RestartForceExitStatus=0 tells systemd to treat exit 0 as failure for restart.
# This way SIGUSR1 triggers a restart while ExecStartPre still gates on OCMC.
Restart=on-failure
RestartForceExitStatus=0
RestartSec=5s
StandardOutput=journal
StandardError=journal
SyslogIdentifier=fleet-gateway

TimeoutStartSec=10
TimeoutStopSec=10

[Install]
WantedBy=default.target
