# OpenClaw Fleet Configuration

# Mission Control
POSTGRES_DB=mission_control
POSTGRES_USER=postgres
POSTGRES_PASSWORD=changeme
# Use 5433 to avoid conflict with Plane's PostgreSQL on 5432
POSTGRES_PORT=5433
AUTH_MODE=local
LOCAL_AUTH_TOKEN=changeme-minimum-50-characters-long-secure-random-token-here
BASE_URL=http://localhost:8000
CORS_ORIGINS=http://localhost:3000

# Fleet Identity
FLEET_USER_NAME=Fleet Admin

# OCF Python Gateway (fleet orchestrator WS server)
# NOTE: This is NOT the vendor (openarms) gateway port.
# The vendor gateway reads its port from ~/.openarms/openarms.json (gateway.port, default 18789).
OCF_GATEWAY_PORT=9400
OCF_MISSION_CONTROL_URL=http://localhost:8000
OCF_CLAUDE_MODEL=opus
OCF_DEFAULT_MODE=think
# Plane (issue tracker integration)
# Set PLANE_URL to your Plane instance base URL (e.g. http://localhost:8080)
# Set PLANE_API_KEY to a personal API token from Plane → Settings → API Tokens
PLANE_URL=http://localhost:8080
PLANE_API_KEY=your-plane-api-token-here

# LightRAG (Knowledge Graph)
LIGHTRAG_PORT=9621
LIGHTRAG_LOG_LEVEL=INFO
# LLM for entity/relationship extraction (uses LocalAI on host)
LIGHTRAG_LLM_MODEL=hermes
LIGHTRAG_LLM_HOST=http://host.docker.internal:8090/v1
LIGHTRAG_LLM_API_KEY=dummy
# Embedding model (uses LocalAI on host)
# nomic-embed-text-v1.5 on LocalAI (768-dim, runs on CPU, ~140MB)
LIGHTRAG_EMBEDDING_MODEL=nomic-embed
LIGHTRAG_EMBEDDING_HOST=http://host.docker.internal:8090/v1
LIGHTRAG_EMBEDDING_API_KEY=dummy
LIGHTRAG_EMBEDDING_DIM=768
# Fleet domain entity types for knowledge graph (JSON array)
LIGHTRAG_ENTITY_TYPES=["system","agent","command","hook","skill","plugin","layer","tool","module","workflow"]
# Reranker — disabled by default (LightRAG supports: cohere, jina, siliconcloud, vllm)
# LIGHTRAG_RERANK_BINDING=cohere
# LIGHTRAG_RERANK_MODEL=rerank-v3.5
# LIGHTRAG_RERANK_BY_DEFAULT=false
# Query settings
LIGHTRAG_TOP_K=10
LIGHTRAG_MAX_ASYNC=4
# Optional API key (leave empty for no auth)
LIGHTRAG_API_KEY=

# Claude-Mem (Per-Agent Memory)
# OpenRouter API key for free-tier compression (xiaomi/mimo-v2-flash:free)
CLAUDE_MEM_OPENROUTER_API_KEY=
# ChromaDB disabled by default (SQLite-only mode saves RAM on WSL2)
CLAUDE_MEM_CHROMA_ENABLED=false
